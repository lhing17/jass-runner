{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "运行 run_complete_example.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/examples/python/run_complete_example.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "justMyCode": false
        },
        {
            "name": "运行当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        }
    ]
}
